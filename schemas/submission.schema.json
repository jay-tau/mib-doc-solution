{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MIB Doc Challenge Prediction Object",
  "type": "object",
  "required": [
    "case_id",
    "applicant_name",
    "species_code",
    "home_world",
    "visa_class",
    "sponsor_id",
    "arrival_date",
    "declared_purpose",
    "risk_flags",
    "fee_status",
    "adjudication",
    "confidence"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^MIB-[0-9]{6}$"
    },
    "applicant_name": {
      "type": "string"
    },
    "species_code": {
      "type": "string"
    },
    "home_world": {
      "type": "string"
    },
    "visa_class": {
      "type": "string"
    },
    "sponsor_id": {
      "type": "string",
      "pattern": "^SPN-[0-9]{4}$"
    },
    "arrival_date": {
      "type": "string",
      "format": "date"
    },
    "declared_purpose": {
      "type": "string"
    },
    "risk_flags": {
      "type": "string"
    },
    "fee_status": {
      "type": "string",
      "enum": ["paid", "waived", "unpaid", "unknown"]
    },
    "adjudication": {
      "type": "string",
      "enum": ["APPROVED", "DENIED", "NEEDS_REVIEW"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
